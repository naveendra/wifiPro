rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation for SpeedTest
    function isValidSpeedTest(data) {
      return data.get('userId', '') == request.auth.uid
        && data.get('downloadSpeed', 0) is number
        && data.get('uploadSpeed', 0) is number
        && data.get('ping', 0) is number
        && data.get('unloadedPing', 0) is number
        && data.get('loadedPing', 0) is number
        && data.get('wifiName', '') is string
        && data.get('isp', '') is string
        && data.get('signalStrength', 0) is number
        && data.get('distance', 0) is number
        && (data.get('location', null) == null || (
             data.location.get('lat', 0) is number && 
             data.location.get('lng', 0) is number && 
             data.location.get('city', '') is string
        ))
        && (data.get('timestamp', request.time) == request.time || data.get('timestamp', request.time) is timestamp)
        && data.get('isManual', false) is bool;
    }

    // Validation for UserConfig
    function isValidUserConfig(data) {
      return data.userId == request.auth.uid;
    }

    match /speed_tests/{testId} {
      allow create: if isVerified() && isValidSpeedTest(incoming());
      allow get, list: if isVerified() && resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    match /user_configs/{userId} {
      allow create, update: if isOwner(userId) && isValidUserConfig(incoming());
      allow get: if isOwner(userId);
    }
  }
}
